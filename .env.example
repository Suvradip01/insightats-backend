# ── InSightATS Backend — Environment Variables ──────────────────────────────
# Copy this file to .env on the Oracle Cloud VM and fill in the values.
# DO NOT commit .env to git.

# Runtime environment: "production" or "development"
APP_ENV=production

# Port Uvicorn binds to (Nginx proxies to this)
PORT=8000

# Path to SQLite DB on the Oracle persistent block volume (/data is mounted volume)
DB_PATH=/data/db.sqlite3

# Path to directory containing ner_model/, matcher_model/, complexity_model/
MODEL_DIR=/data/models

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=https://YOUR-APP.vercel.app

# Clerk JWT verification (required for recruiter batch-analyze from the React app)
# Clerk Dashboard → Configure → API Keys → JWT issuer (ends with .clerk.accounts.dev)
CLERK_ISSUER=https://YOUR-INSTANCE.clerk.accounts.dev
# Optional override (defaults to CLERK_ISSUER/.well-known/jwks.json)
# CLERK_JWKS_URL=
# Optional: authorized party / audience if you restrict JWTs in Clerk
# CLERK_AUDIENCE=

# Optional: Enable SHAP explainability (very slow ~60s/request, off by default)
# ENABLE_SHAP=0

# Uvicorn worker count — keep at 1 since models are 1.14 GB singleton in memory
WEB_CONCURRENCY=1
